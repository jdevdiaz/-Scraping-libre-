    {
      "parameters": {
        "jsCode": "const llmResponse = $input.first().json.message?.content\n  || $input.first().json.text\n  || $input.first().json.output\n  || '';\n\nlet productos = [];\ntry {\n  const cleaned = llmResponse.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n  productos = JSON.parse(cleaned);\n} catch (e) {\n  return [{\n    json: {\n      error: true,\n      mensaje: '❌ La IA no pudo extraer productos. Intenta con otro producto o URL.',\n      chatId: $('Parser de Comando').first().json.chatId\n    }\n  }];\n}\n\nconst precios = productos\n  .map(p => parseFloat(p.precio))\n  .filter(p => !isNaN(p) && p > 0);\n\nconst precioPromedio = precios.length\n  ? Math.round(precios.reduce((a, b) => a + b, 0) / precios.length)\n  : 0;\nconst masBarato = precios.length ? Math.min(...precios) : 0;\nconst masCaro = precios.length ? Math.max(...precios) : 0;\n\nconst query = $('Parser de Comando').first().json.buscar;\nconst url = $('Parser de Comando').first().json.url;\nconst guardar = $('Parser de Comando').first().json.guardar;\nconst chatId = $('Parser de Comando').first().json.chatId;\nconst fecha = new Date().toISOString().split('T')[0];\n\nconst reporte = `🛒 *REPORTE DE PRODUCTOS*\\n━━━━━━━━━━━━━━━━━━━━━━━━\\n🔎 *Búsqueda:* ${query}\\n🌐 *Fuente:* ${url}\\n\\n💰 *Precio Promedio:* $${precioPromedio.toLocaleString()}\\n📉 *Más Barato:* $${masBarato.toLocaleString()}\\n📈 *Más Caro:* $${masCaro.toLocaleString()}\\n📦 *Total Items:* ${productos.length}\\n\\n📅 Fecha: ${fecha}`;\n\nreturn [{\n  json: {\n    tipo: 'dinamico',\n    url, query, productos,\n    datosJson: JSON.stringify(productos),\n    precioPromedio, masBarato, masCaro,\n    totalItems: productos.length,\n    reporte, guardar, chatId, fecha\n  }\n}];"
      },
