# Ruta al archivo JSON de credenciales de la cuenta de servicio de Google
GOOGLE_CREDENTIALS_PATH=credentials/service_account.json

# Nombre exacto del libro de Google Sheets
GOOGLE_SHEET_NAME=Scraping_Pipeline

# ID del spreadsheet de Google Sheets (alternativa al nombre)
GOOGLE_SHEETS_ID=TU_SPREADSHEET_ID_AQUI

# URL publica de esta app (para el enlace que n8n envia por Telegram)
STREAMLIT_PUBLIC_URL=http://localhost:8501
